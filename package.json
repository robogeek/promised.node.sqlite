{
  "name": "promised.node.sqlite",
  "version": "1.0.0",
  "type": "module",
  "description": "You can use async/await for node:sqlite",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "author": {
    "name": "David Herron",
    "email": "david@davidherron.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/robogeek/promised.node.sqlite.git"
  },
  "engines": {
    "node": ">= 24.0.0"
  },
  "keywords": [
    "node",
    "typescript",
    "module",
    "sqlite3",
    "async",
    "promise"
  ],
  "license": "MIT",
  "scripts": {
    "name": "echo $npm_package_name",
    "start": "node .",
    "build": "tsc && tscp",
    "watch": "tsc -w & tscp -w",
    "clean": "rimraf dist",
    "build.test": "tsc -p tsconfig.test.json && tscp",
    "test": "npm run build.test && node --test dist.test/test/**/*.spec.js",
    "test.watch": "npm run build.test && node --test --watch dist.test/test/**/*.spec.js",
    "clean.test": "rimraf dist.test"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "rimraf": "^3.0.2",
    "typescript": "^6.x",
    "typescript-cp": "^0.1.9"
  }
}
