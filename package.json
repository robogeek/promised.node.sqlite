{
  "name": "promised.node.sqlite",
  "version": "0.2.0",
  "description": "You can use async/await for node:sqlite",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "author": {
    "name": "David Herron",
    "email": "david@davidherron.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/robogeek/promised.node.sqlite.git"
  },
  "engines": {
    "node": ">= 24.0.0"
  },
  "keywords": [
    "node",
    "typescript",
    "module",
    "sqlite3",
    "async",
    "promise"
  ],
  "license": "MIT",
  "scripts": {
    "name": "echo $npm_package_name",
    "start": "node .",
    "build.tsc": "tsc && bin/copy \"src/**/!(*.ts)\" \"dist\" \"**/node_modules/**\" \"**/.DS_Store\"",
    "clean": "rimraf dist",
    "build.util": "tsc --outDir utils utils/index.ts",
    "build.test": "tsc -p tsconfig.test.json && bin/copy \"src/**/!(*.ts)\" \"dist.test/src\" \"**/node_modules/**\" \"**/.DS_Store\"",
    "test": "npm run build.test && ava -v",
    "test.watch": "npm run build.test && ava --watch",
    "clean.test": "rimraf dist.test"
  },
  "devDependencies": {
    "ava": "^3.15.0",
    "rimraf": "^3.0.2",
    "typescript": "^6.x"
  },
  "ava": {
    "files": [
      "dist.test/test/**/*.spec.js"
    ]
  }
}
